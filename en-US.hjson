Mods: {
	Eternia: {
		Keybinds: {
			"Open Eternia Menu.DisplayName": Open Eternia Menu
			"Toggle Soul UI.DisplayName": Toggle Soul UI
			"Toggle Stats UI.DisplayName": Toggle Stats UI
			"Toggle Passive UI.DisplayName": Toggle Passive UI
			"Toggle Boss Codex.DisplayName": Toggle Boss Codex
			"Class Skill.DisplayName": Class Skill
			"Change Note.DisplayName": Change Note
			"Elemental Ultimate.DisplayName": Elemental Ultimate
			"Cursed Burst.DisplayName": Cursed Burst
		}

		Buffs: {
			SoulLessDebuff: {
				DisplayName: Lost Soul
				Description: A body without a soul is worthless...
			}

			SoulViolationDebuff: {
				DisplayName: Soul Violation
				Description: Your soul rejects the weapon you tried to use.
			}

			BleedDebuff: {
				DisplayName: Bleed
				Description: Losing blood over time.
			}

			BeastMinionBuff: {
				DisplayName: Beast Pack
				Description: A beast fights at your side.
			}

			DroneMinionBuff: {
				DisplayName: Drone Fleet
				Description: Your drones are deployed.
			}

			LegionMinionBuff: {
				DisplayName: Legion
				Description: Your legion is deployed.
			}

			WarriorsBrewBuff: {
				DisplayName: Warrior's Brew
				Description: +10% melee damage, +6% crit and faster swings.
			}

			ArcanistsBrewBuff: {
				DisplayName: Arcanist's Brew
				Description: +10% magic damage, +6% crit and cheaper spells.
			}

			HuntersBrewBuff: {
				DisplayName: Hunter's Brew
				Description: +10% ranged damage, +6% crit and faster attacks.
			}

			PackleadersBrewBuff: {
				DisplayName: Packleader's Brew
				Description: +12% summon damage, longer and faster whips.
			}

			BattleTonicBuff: {
				DisplayName: Battle Tonic
				Description: +6% damage for every class at once.
			}

			GrandBattleTonicBuff: {
				DisplayName: Grand Battle Tonic
				Description: +10% damage for every class, and +4% crit.
			}

			EternalFeastBuff: {
				DisplayName: Eternal Feast
				Description: Steady regeneration, a little of everything. Stay fed.
			}

			WardingTonicBuff: {
				DisplayName: Warding Tonic
				Description: +8 defense and 5% damage reduction. Brew before a boss.
			}

			CoolantDraughtBuff: {
				DisplayName: Coolant Draught
				Description: Energy Gunner: faster cooling, less heat per shot, overheat shielded.
			}

			AdrenalineDraughtBuff: {
				DisplayName: Adrenaline Draught
				Description: Gunner: Momentum builds faster and decays slower.
			}

			FocusDraughtBuff: {
				DisplayName: Focus Draught
				Description: Archer: Concentration regenerates faster and is spent more gently.
			}

			WarcryDraughtBuff: {
				DisplayName: Warcry Draught
				Description: Fighter: a longer Combo chain that holds together longer.
			}

			BloodlustDraughtBuff: {
				DisplayName: Bloodlust Draught
				Description: Beast Tamer: Ferocity surges faster and cools slower.
			}

			OverdriveDraughtBuff: {
				DisplayName: Overdrive Draught
				Description: Tech Summoner: the Power Core charges faster, Overdrive lasts longer.
			}
		}

		Items: {
			WarriorsBrew: {
				DisplayName: Warrior's Brew
				Tooltip: +10% melee damage, +6% crit and faster swings for every warrior soul.
			}

			ArcanistsBrew: {
				DisplayName: Arcanist's Brew
				Tooltip: +10% magic damage, +6% crit and cheaper spells for every mage soul.
			}

			HuntersBrew: {
				DisplayName: Hunter's Brew
				Tooltip: +10% ranged damage, +6% crit and faster attacks for every ranger soul.
			}

			PackleadersBrew: {
				DisplayName: Packleader's Brew
				Tooltip: +12% summon damage, longer and faster whips for every summoner soul.
			}

			BattleTonic: {
				DisplayName: Battle Tonic
				Tooltip: +6% damage for all four classes at once. Never wasted, whatever your soul.
			}

			GrandBattleTonic: {
				DisplayName: Grand Battle Tonic
				Tooltip:
					'''
					+10% damage for all four classes, and +4% crit.
					The hardmode upgrade of the Battle Tonic.
					'''
			}

			EternalFeast: {
				DisplayName: Eternal Feast
				Tooltip: A long, hearty meal: steady regeneration and a little of everything. Stay fed.
			}

			WardingTonic: {
				DisplayName: Warding Tonic
				Tooltip: +8 defense and 5% damage reduction. Brew a few before a boss you keep dying to.
			}

			CoolantDraught: {
				DisplayName: Coolant Draught
				Tooltip: Energy Gunner tonic: cool faster, gain less heat per shot, shrug off one overheat.
			}

			AdrenalineDraught: {
				DisplayName: Adrenaline Draught
				Tooltip: Gunner tonic: Momentum builds faster and decays slower.
			}

			FocusDraught: {
				DisplayName: Focus Draught
				Tooltip: Archer tonic: Concentration regenerates faster and is spent more gently.
			}

			WarcryDraught: {
				DisplayName: Warcry Draught
				Tooltip: Fighter tonic: +5 max Combo and a longer combo window.
			}

			BloodlustDraught: {
				DisplayName: Bloodlust Draught
				Tooltip: Beast Tamer tonic: Ferocity surges faster and cools slower.
			}

			OverdriveDraught: {
				DisplayName: Overdrive Draught
				Tooltip: Tech Summoner tonic: the Power Core charges faster and Overdrive lasts longer.
			}

			CorruptedSoulCore: {
				DisplayName: Corrupted Soul Core
				Tooltip:
					'''
					Feeds a corrupted Soul into a dormant vessel and wakes it.
					Summons Prototype-01. Built from salvaged tech at an anvil.
					'''
			}

			PrototypeCore: {
				DisplayName: Prototype Core
				Tooltip: Salvaged from Prototype-01. The material for advanced soul-tech gear.
			}

			RefinedPrototypeCore: {
				DisplayName: Refined Prototype Core
				Tooltip: Salvaged from Prototype-02. The material for Hardmode soul-tech gear.
			}

			AwakenedSoulCore: {
				DisplayName: Awakened Soul Core
				Tooltip:
					'''
					Reforges a Prototype Core into a live vessel and wakes the second machine.
					Summons Prototype-02. A Hardmode craft at a Mythril/Orichalcum Anvil.
					'''
			}

			SoulforgedGreatsaber: {
				DisplayName: Soulforged Greatsaber
				Tooltip: The Hardmode evolution of the Sabre. Heavier swings, heavier crescents.
			}

			SoulstoneOre: {
				DisplayName: Soulstone
				Tooltip: Soul residue soaked into common rock. Needs an Iron pickaxe.
			}

			AnimiteOre: {
