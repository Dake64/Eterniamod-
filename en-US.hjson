			SoulAscension: {
				DisplayName: Soul Ascension
				Tooltip:
					'''
					Permanently strengthens your active class Soul by one Ascension tier.
					Each tier adds class damage, crit, max life and defense.
					A Soul Reforge never undoes it. Ritual performed at a Demon Altar.
					'''
			}

			SoulforgedSabre: {
				DisplayName: Soulforged Sabre
				Tooltip: Each swing throws an energy crescent. Forged from Prototype-01's own Soul-tech.
